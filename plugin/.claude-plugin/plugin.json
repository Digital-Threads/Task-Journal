{
  "name": "task-journal",
  "version": "0.1.0",
  "description": "Append-only journal of AI-coding task reasoning chains: hypotheses, decisions, rejections, evidence. Renders compact resume packs so an agent can pick up a 2-week-old task with full context.",
  "author": {
    "name": "Mher Shahinyan"
  },
  "license": "MIT",
  "keywords": [
    "task-journal",
    "memory",
    "reasoning",
    "ai-coding",
    "mcp"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "wsl -d Ubuntu -- bash -lc 'task-journal ingest-hook --kind=UserPromptSubmit --text=\"$CLAUDE_HOOK_TEXT\" || true'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "wsl -d Ubuntu -- bash -lc 'task-journal ingest-hook --kind=PostToolUse --text=\"$CLAUDE_HOOK_TEXT\" || true'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "wsl -d Ubuntu -- bash -lc 'task-journal ingest-hook --kind=Stop --text=\"$CLAUDE_HOOK_TEXT\" || true'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
